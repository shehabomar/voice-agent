# ─────────────────────────────────────────────────────────────────────────────
# Google Calendar — Service Account
# ─────────────────────────────────────────────────────────────────────────────
# Paste the *entire* contents of your Service Account JSON key file here,
# compacted onto a single line (no actual newlines inside the value).
# The private_key field should still use \n escape sequences — that's correct.
#
# How to get it:
#   1. Google Cloud Console → IAM & Admin → Service Accounts
#   2. Create a key (JSON) → download the file
#   3. Run:  python -c "import json,sys; d=json.load(open('key.json')); print(json.dumps(d))"
#   4. Paste the output as the value below (no extra quotes needed)
GOOGLE_CREDENTIALS_JSON=

# Optional: target a specific calendar by ID instead of the default "primary".
# Find your calendar ID in Google Calendar → Settings → [calendar] → Calendar ID.
CALENDAR_ID=primary

# ─────────────────────────────────────────────────────────────────────────────
# Vapi — Voice AI platform
# ─────────────────────────────────────────────────────────────────────────────
# Sign up at https://dashboard.vapi.ai → Account → API Keys

# Private/Secret key — used server-side to create assistants via the REST API.
VAPI_API_KEY=

# Public/Publishable key — safe to expose in browser JS, used by the /demo page.
# Same dashboard page: look for "Public Key" (separate from the Secret key).
VAPI_PUBLIC_KEY=

# (Render deployment only) — set this to the assistant ID created by run_agent.py
# so the hosted /demo page knows which assistant to connect to.
# Leave blank for local use — run_agent.py sets this automatically.
VAPI_ASSISTANT_ID=
